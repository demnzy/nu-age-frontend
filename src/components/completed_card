import flet as ft

def get_completed_course_card(course_name, course_id, page: ft.Page):
    
    def animate(e):
        # A gentler scale effect (1.05 instead of 1.1) to feel less urgent
        card.scale = 1.05 if card.scale == 1 else 1
        e.control.update()

    card = ft.Container(
        width=200,             
        height=130,
        bgcolor=ft.Colors.WHITE,
        border_radius=12,
        padding=15,
        offset=ft.Offset(0, 0),
        scale=1,
        # Flatter design: Replaced the drop shadow with a subtle, static border
        border=ft.border.all(1, ft.Colors.with_opacity(0.08, ft.Colors.BLACK)),
        animate_scale=ft.Animation(
            duration=400, # Slightly faster, smoother curve (EASE_OUT instead of BOUNCE)
            curve=ft.AnimationCurve.EASE_OUT,
        ),
        on_hover=animate,
        on_click=lambda _: page.go(f"/courses/{course_id}/{course_name.replace(' ', '-').lower()}"),
        
        content=ft.Column(
            alignment=ft.MainAxisAlignment.SPACE_BETWEEN,
            controls=[
                # Top Row: Certificate Icon & Completed Badge
                ft.Row([
                    ft.Icon(
                        ft.Icons.WORKSPACE_PREMIUM_ROUNDED, 
                        size=28, 
                        color=ft.Colors.GREEN_600 
                    ),
                    ft.Container(
                        padding=ft.padding.symmetric(horizontal=8, vertical=4),
                        bgcolor=ft.Colors.GREEN_50,
                        border_radius=10,
                        content=ft.Text("Completed", size=10, weight=ft.FontWeight.BOLD, color=ft.Colors.GREEN_700)
                    )
                ], alignment=ft.MainAxisAlignment.SPACE_BETWEEN),
                
                # Course Title: Slightly muted weight compared to active courses
                ft.Text(
                    course_name, 
                    size=14, 
                    weight=ft.FontWeight.W_600, 
                    max_lines=2, 
                    overflow=ft.TextOverflow.ELLIPSIS,
                    color=ft.Colors.ON_SURFACE
                ),
                
                # Footer: Replaces the progress bar with a clear "Review" call to action
                ft.Row(
                    spacing=4,
                    alignment=ft.MainAxisAlignment.START,
                    controls=[
                        ft.Text("Review Material", size=11, color=ft.Colors.ON_SURFACE_VARIANT, weight=ft.FontWeight.W_500),
                        ft.Icon(ft.Icons.ARROW_FORWARD_ROUNDED, size=12, color=ft.Colors.ON_SURFACE_VARIANT)
                    ]
                )
            ]
        )
    )
    return card